MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority&appName=Cluster0
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Use one of these in production. Prefer FIREBASE_SERVICE_ACCOUNT_JSON in Render.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=

GROQ_API_KEY=gsk_your_key
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

GEMINI_API_KEY=your-gemini-api-key
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_VOICE=Kore

CARTESIA_API_KEY=
CARTESIA_VERSION=2026-03-01
CARTESIA_TTS_MODEL=sonic-3.5
CARTESIA_TTS_FORMAT=wav
CARTESIA_TTS_SAMPLE_RATE=44100
CARTESIA_TTS_SPEED=0.78

PUBLIC_BASE_URL=https://your-render-service.onrender.com
DEBUG_SAVE_VOICE_UPLOADS=false
